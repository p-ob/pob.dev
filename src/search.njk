<h1>Search</h1>

<pagefind-config excerpt-length="20"></pagefind-config>
<pagefind-input></pagefind-input>
<pagefind-summary></pagefind-summary>
<pagefind-results></pagefind-results>

<link href="/pagefind/pagefind-component-ui.css" rel="stylesheet">
<style>
	:root {
		--pf-text: var(--font-color);
		--pf-background: var(--page-background-color);
		--pf-mark: var(--font-color);
		--pf-border-radius: 4px;
		--pf-font: inherit;
	}

	@media (prefers-color-scheme: dark) {
		:root {
			--pf-border: #333;
			--pf-border-focus: #555;
			--pf-hover: #252525;
			--pf-skeleton: #2a2a2a;
			--pf-skeleton-shine: #333;
			--pf-outline-focus: #58a6ff;
		}
	}
</style>
<script src="/pagefind/pagefind-component-ui.js" type="module"></script>
<script type="module">
	const { getInstanceManager } = window.PagefindComponents;
	const instance = getInstanceManager().getInstance("default");

	// Listeners must be registered before triggerSearch() below fires the
	// initial deep-link query -- triggerSearch dispatches "search"
	// synchronously, so anything registered after it would miss that event.

	// Keep URL in sync with the search term
	instance.on("search", (term) => {
		const url = new URL(window.location);
		if (term) {
			url.searchParams.set("q", term);
		} else {
			url.searchParams.delete("q");
		}
		history.replaceState(null, "", url);
	});

	// Easter egg: searching "Pippin" summons an animated Bernese Mountain Dog.
	// Also fires from a deep link (e.g. /search/?q=Pippin) via triggerSearch below.
	let pippinModule;
	instance.on("search", async (term) => {
		if (!term || !/pippin/i.test(term) || document.querySelector("pob-pippin")) {
			return;
		}
		pippinModule ??= import("/assets/js/components/pippin.js");
		await pippinModule;
		document.body.appendChild(document.createElement("pob-pippin"));
	});

	// Load initial query from URL
	const params = new URLSearchParams(window.location.search);
	const initialQuery = params.get("q");
	if (initialQuery) {
		instance.triggerSearch(initialQuery);
	}

	// The `autofocus` attribute on <pagefind-input> above doesn't work: the
	// browser consumes/strips it from that element during native autofocus
	// processing before the component's own JS ever reads it, since the
	// custom element itself isn't a focusable target -- only the real
	// <input> it renders internally is. Focus that directly instead, and
	// only after triggerSearch() above: the component skips writing a
	// deep-link query into the input's value while it's already focused
	// (so it doesn't clobber text the user is actively typing).
	document.querySelector("pagefind-input input")?.focus();
</script>
