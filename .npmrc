node-options=--experimental-vm-modules

# Refuse to install a package version published less than this many days
# ago. Most malicious/compromised versions are caught and unpublished
# within hours, so this blocks the narrow window supply-chain attacks
# rely on. `npm ci` installs exactly what package-lock.json already pins
# so it ignores this, but `npm audit signatures` re-resolves each locked
# package against the registry and does honor it - CI overrides it to 0
# via NPM_CONFIG_MIN_RELEASE_AGE since a pinned, already-reviewed
# lockfile has nothing left for the cooldown to protect against.
min-release-age=7